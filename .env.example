VITE_STRIPE_PRICE_BEWEGUNG=price_...
VITE_STRIPE_PRICE_PRAXIS=price_...
VITE_STRIPE_PRICE_ANATOMIE=price_...
VITE_STRIPE_PRICE_TRAINING=price_...
VITE_STRIPE_PRICE_TELEFON=price_...
