# Supabase (from your Supabase project settings)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Paddle (client-side token — starts with test_ for sandbox, live_ for production)
VITE_PAYMENTS_CLIENT_TOKEN=test_...

# Sentry (optional — error monitoring; get DSN from sentry.io project settings)
VITE_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# App version (optional — shown in Sentry releases)
VITE_APP_VERSION=1.0.0
